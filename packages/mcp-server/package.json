{
  "name": "@deltapilot/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "deltapilot-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/bundle-cli.mjs && chmod +x dist/cli.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@deltapilot/core": "workspace:*",
    "@deltapilot/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "better-sqlite3": "^11.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.25.0",
    "execa": "^9.5.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
