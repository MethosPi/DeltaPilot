# Repository root for DeltaPilot to track
DP_REPO=/abs/path/to/your/repo

# Agent UUID — generate with: node scripts/register-agent.mjs
DP_AGENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SQLite database path (defaults to <DP_REPO>/.deltapilot-data.db)
# DP_DB=/abs/path/to/custom.db

# Dashboard HTTP server
DP_DASHBOARD_HOST=0.0.0.0
DP_DASHBOARD_PORT=3000
DP_DASHBOARD_USERNAME=admin
DP_DASHBOARD_PASSWORD=change-me
