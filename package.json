{
  "name": "deltapilot",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source AI Agent Orchestrator — Jira for AI Agents",
  "license": "MIT",
  "author": "Davide Pizzo <davide.pizzo@brickken.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MethosPi/DeltaPilot.git"
  },
  "homepage": "https://github.com/MethosPi/DeltaPilot#readme",
  "bugs": {
    "url": "https://github.com/MethosPi/DeltaPilot/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dashboard": "pnpm exec turbo run build --filter=@deltapilot/dashboard && node ./apps/dashboard/dist/cli.js",
    "runner": "pnpm --filter @deltapilot/runner build && node ./apps/runner/dist/cli.js",
    "demo": "pnpm build && node ./scripts/demo.ts",
    "agent:register": "node ./scripts/register-agent.mjs",
    "docker:build": "docker build -t deltapilot:local .",
    "test": "turbo run test && node --test ./scripts/register-agent.test.mjs",
    "test:register-agent": "node --test ./scripts/register-agent.test.mjs",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.scripts.json --noEmit",
    "lint": "turbo run lint"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "@types/node": "^22.10.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
